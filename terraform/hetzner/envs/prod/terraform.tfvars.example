# prod env — Terraform variables
# Copy to terraform.tfvars (git-ignored) and fill in real values.

hcloud_token        = "your-hetzner-api-token"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# RESTRICT in production — leaving SSH open to 0.0.0.0/0 is a liability.
# ssh_source_ips = ["203.0.113.0/24"]

ghcr_auth_b64 = "base64('username:ghcr-token')"

# user-service secrets (prod)
user_postgres_password  = "a-strong-prod-password-at-least-16-chars"
user_redis_password     = "a-strong-prod-password-at-least-16-chars"
user_service_jwt_secret = "a-strong-prod-secret-at-least-32-chars"
